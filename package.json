{
  "name": "ust_buysell_poc",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/postgres": "^2.2.0",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@cap-js/cds-test": ">=0.4.1"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "node --test"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "postgres"
      },
      "auth": {
        "kind": "dummy"
      },
      "ZAPI_PURCHASEORDER_PROCESS_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/ZAPI_PURCHASEORDER_PROCESS_SRV",
        "credentials": {
          "destination": "S4H",
          "path": "/sap/opu/odata/sap/API_PURCHASEORDER_PROCESS_SRV"
        }
      },
      "ZAPI_SALES_CONTRACT_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/ZAPI_SALES_CONTRACT_SRV",
        "credentials": {
          "destination": "S4H",
          "path": "/sap/opu/odata/sap/API_SALES_CONTRACT_SRV"
        }
      },
      "OP_API_PROJECT_V3_0001": {
        "kind": "odata",
        "model": "srv/external/OP_API_PROJECT_V3_0001",
        "credentials": {
          "destination": "S4H",
          "path": "/sap/opu/odata4/sap/api_project_v3/srvd_a2x/sap/project/0001"
        },
        "csrf": true,
        "csrfInBatch": true
      },
      "[production]": {
        "connectivity": true,
        "destinations": true
      }
    }
  },
  "private": true
}
