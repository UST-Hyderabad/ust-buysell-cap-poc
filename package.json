{
  "name": "ust_buysell_poc",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/postgres": "^2",
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "postgres"
      },
      "auth": {
        "kind": "dummy"
      },
      "ZAPI_PURCHASEORDER_PROCESS_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/ZAPI_PURCHASEORDER_PROCESS_SRV",
        "credentials": {
          "destination": "S4H",
          "path": "/sap/opu/odata/sap/API_PURCHASEORDER_PROCESS_SRV"
        },
        "csrf": true,
        "csrfInBatch": true
      }
    }
  },
  "private": true
}
